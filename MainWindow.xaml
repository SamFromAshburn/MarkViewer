<Window x:Class="MarkViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MarkViewer" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e">

    <Window.Resources>
        <!-- TreeView item styles for dark theme -->
        <Style x:Key="FolderNavTreeView" TargetType="TreeView">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="Padding" Value="4"/>
        </Style>

        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="2,2,2,2"/>
            <Setter Property="Margin" Value="0,1,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#ffffff"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#333333" Padding="6">
            <DockPanel>
                <Button x:Name="BtnOpenFolder" Content="📁 Open Folder" Click="BtnOpenFolder_Click"
                        Padding="10,5" Margin="0,0,8,0"
                        Background="#0e639c" Foreground="White" BorderThickness="0"
                        FontSize="13" Cursor="Hand"/>
                <Button x:Name="BtnToggleNav" Content="☰" Click="BtnToggleNav_Click"
                        Padding="8,5" Margin="0,0,8,0"
                        Background="#0e639c" Foreground="White" BorderThickness="0"
                        FontSize="13" Cursor="Hand" ToolTip="Toggle navigation panel"/>
                <TextBlock x:Name="TxtCurrentFile" Text="No file open" 
                           Foreground="#999999" VerticalAlignment="Center" 
                           FontSize="13" Margin="8,0,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="280" MinWidth="180"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Folder navigation panel -->
            <Border Grid.Column="0" x:Name="NavPanel" Background="#252526">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#333333" Padding="10,6">
                        <DockPanel>
                            <TextBlock Text="E X P L O R E R" Foreground="#bbbbbb" FontSize="11" 
                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Search files panel (Ctrl+Shift+F) -->
                    <Border x:Name="SearchPanel" DockPanel.Dock="Top" Background="#1e1e1e" 
                            Padding="8,6" Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" Click="BtnCloseSearch_Click"
                                    Background="Transparent" Foreground="#999" BorderThickness="0"
                                    FontSize="12" Cursor="Hand" Padding="4,0" Margin="4,0,0,0"/>
                            <TextBox x:Name="TxtSearch" Background="#3c3c3c" Foreground="White"
                                     BorderBrush="#007acc" BorderThickness="1" Padding="6,3"
                                     FontSize="13" KeyDown="TxtSearch_KeyDown"
                                     Tag="Search in files..."/>
                        </DockPanel>
                    </Border>

                    <!-- Search results list -->
                    <ListBox x:Name="SearchResults" DockPanel.Dock="Top" 
                             Background="#252526" BorderThickness="0" Foreground="#cccccc"
                             Visibility="Collapsed" MaxHeight="400"
                             SelectionChanged="SearchResults_SelectionChanged"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2">
                                    <TextBlock Text="{Binding FileName}" Foreground="#e8e8e8" 
                                               FontSize="12" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding RelativePath}" Foreground="#888" 
                                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding MatchPreview}" Foreground="#aaa" 
                                               FontSize="11" TextTrimming="CharacterEllipsis"
                                               Margin="0,1,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TreeView x:Name="FolderTree" 
                              Style="{StaticResource FolderNavTreeView}"
                              SelectedItemChanged="FolderTree_SelectedItemChanged"
                              VirtualizingPanel.IsVirtualizing="True"/>
                </DockPanel>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3" Background="#1e1e1e" 
                          HorizontalAlignment="Center" VerticalAlignment="Stretch"
                          Cursor="SizeWE"/>

            <!-- Markdown viewer with find bar overlay -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Find in page bar (Ctrl+F) -->
                <Border x:Name="FindBar" Grid.Row="0" Background="#3c3c3c" 
                        Padding="8,5" Visibility="Collapsed">
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="✕" Click="BtnCloseFindBar_Click"
                                Background="Transparent" Foreground="#999" BorderThickness="0"
                                FontSize="14" Cursor="Hand" Padding="6,2" Margin="4,0,0,0"
                                ToolTip="Close (Escape)"/>
                        <TextBlock DockPanel.Dock="Right" x:Name="TxtFindCount" 
                                   Text="" Foreground="#999" VerticalAlignment="Center"
                                   FontSize="12" Margin="8,0,0,0"/>
                        <Button DockPanel.Dock="Right" Content="▼" Click="BtnFindNext_Click"
                                Background="Transparent" Foreground="#ccc" BorderThickness="0"
                                FontSize="11" Cursor="Hand" Padding="6,2" Margin="2,0,0,0"
                                ToolTip="Next match (Enter)"/>
                        <Button DockPanel.Dock="Right" Content="▲" Click="BtnFindPrev_Click"
                                Background="Transparent" Foreground="#ccc" BorderThickness="0"
                                FontSize="11" Cursor="Hand" Padding="6,2" Margin="2,0,0,0"
                                ToolTip="Previous match (Shift+Enter)"/>
                        <TextBox x:Name="TxtFind" Background="#3c3c3c" Foreground="White"
                                 BorderBrush="#007acc" BorderThickness="1" Padding="6,3"
                                 FontSize="13" KeyDown="TxtFind_KeyDown"
                                 TextChanged="TxtFind_TextChanged"/>
                    </DockPanel>
                </Border>

                <wv2:WebView2 x:Name="MarkdownViewer" Grid.Row="1"
                              DefaultBackgroundColor="#1e1e1e"/>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#007acc" Padding="6,3">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="White" FontSize="12"/>
                <TextBlock x:Name="TxtWordCount" Text="" Foreground="#ffffffcc" FontSize="12"
                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
